PORT=8080
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Internal Hermes WebUI bind — default port 9120 leaves 9119 free for upstream
# `hermes dashboard` when run manually from `/tui`. Public HTTPS uses the same Railway
# $PORT (`/`) for WebUI.
# Kanban (official docs) is on `hermes dashboard` at `HERMES_DASHBOARD_HOST` /
# `HERMES_DASHBOARD_PORT` (default 127.0.0.1:9119), exposed on Railway via
# `HERMES_DASHBOARD_MOUNT_PATH` (default `/hermes-dashboard`), not Hermes WebUI `/`.
# HERMES_WEBUI_HOST=127.0.0.1
# HERMES_WEBUI_PORT=9120
# HERMES_DASHBOARD_HOST=127.0.0.1
# HERMES_DASHBOARD_PORT=9119
# HERMES_DASHBOARD_MOUNT_PATH=/hermes-dashboard

# Set by the multi-service Railway template.
SEARXNG_URL=http://searxng:8080

# Required for browser cloud_provider: firecrawl and web extract (when set in HERMES_CONFIG_B64).
# FIRECRAWL_API_KEY=

# Optional: configure Hermes directly from Railway variables instead of the dashboard.
# OPENROUTER_API_KEY=
# Base64-encoded config.yaml overlay merged into /data/config.yaml on every boot.
# Recommended keys inside the decoded YAML:
#   toolsets: [hermes-cli]
#   web.search_backend: searxng   (uses SEARXNG_URL)
#   browser.cloud_provider: firecrawl   (uses FIRECRAWL_API_KEY)
#   auxiliary.vision → openai/gpt-4o-mini on openrouter (for non-vision main models)
# HERMES_CONFIG_B64=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GLM_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=
# HF_TOKEN=

# Optional messaging channels.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_ALLOWED_USERS=

# Cursor Cloud Agent delegation (cursor-cloud plugin + cursor-delegate skill)
# CURSOR_API_KEY=
# CURSOR_WEBHOOK_SECRET=
# CURSOR_WEBHOOK_URL=https://your-railway-domain/webhooks/cursor
# CURSOR_DEFAULT_REPOSITORY=owner/repo
# CURSOR_MAX_ACTIVE=3
# CURSOR_ALLOWED_REPOS=owner/repo,owner/other
# GITHUB_TOKEN=
